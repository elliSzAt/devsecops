{
  "policy_name": "DevSecOps Security Gate Policy",
  "version": "1.0",
  "description": "Defines pass/fail criteria for security scans in CI/CD pipeline",
  "enforcement": {
    "blocking_rules": [
      {
        "id": "BLOCK-001",
        "description": "Block on any CRITICAL vulnerability",
        "condition": "critical_count > 0",
        "action": "BLOCK",
        "exception_process": "Requires Security Lead + Engineering Manager approval via Jira SEC ticket"
      },
      {
        "id": "BLOCK-002",
        "description": "Block on HIGH vulnerabilities exceeding threshold",
        "condition": "high_count > 3",
        "action": "BLOCK",
        "exception_process": "Requires Security Lead approval with remediation timeline (<= 7 days)"
      },
      {
        "id": "BLOCK-003",
        "description": "Block on container running as root",
        "condition": "container_runs_as_root == true",
        "action": "BLOCK",
        "exception_process": "No exception allowed"
      }
    ],
    "warning_rules": [
      {
        "id": "WARN-001",
        "description": "Warn on HIGH vulnerabilities (1-3)",
        "condition": "high_count >= 1 AND high_count <= 3",
        "action": "WARN",
        "sla": "Fix within 7 business days"
      },
      {
        "id": "WARN-002",
        "description": "Warn on MEDIUM vulnerabilities",
        "condition": "medium_count > 0",
        "action": "WARN",
        "sla": "Fix within 30 business days"
      },
      {
        "id": "WARN-003",
        "description": "Warn on outdated dependencies",
        "condition": "outdated_deps > 5",
        "action": "WARN",
        "sla": "Review in next sprint"
      }
    ],
    "pass_rules": [
      {
        "id": "PASS-001",
        "description": "Pass when no CRITICAL/HIGH and MEDIUM <= 5",
        "condition": "critical_count == 0 AND high_count == 0 AND medium_count <= 5"
      }
    ]
  },
  "sla_definitions": {
    "CRITICAL": {
      "remediation_time": "24 hours",
      "notification": ["security-team", "engineering-lead", "ciso"],
      "escalation": "VP Engineering if not fixed in 48h"
    },
    "HIGH": {
      "remediation_time": "7 business days",
      "notification": ["security-team", "dev-team-lead"],
      "escalation": "Engineering Manager if not fixed in 14 days"
    },
    "MEDIUM": {
      "remediation_time": "30 business days",
      "notification": ["dev-team"],
      "escalation": "Team Lead if not fixed in 45 days"
    },
    "LOW": {
      "remediation_time": "Next quarter",
      "notification": ["backlog"],
      "escalation": "None"
    }
  },
  "exception_workflow": {
    "allowed": true,
    "max_duration": "30 days",
    "required_approvers": ["security-lead"],
    "critical_approvers": ["security-lead", "engineering-manager", "ciso"],
    "documentation_required": true,
    "re_review_required": true
  }
}
